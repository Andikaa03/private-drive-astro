---

---

<footer class="bg-inverse-surface text-white">
  <div
    class="grid grid-cols-1 md:grid-cols-4 gap-16 px-6 md:px-20 py-24 w-full"
  >
    <!-- Brand -->
    <div class="col-span-1">
      <span
        class="text-white mb-8 block leading-none"
        >
        <svg viewBox="0 0 100 60" class="w-12 h-auto text-white fill-current opacity-90" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 0 L60 30 L0 60 L15 30 Z" />
          <path d="M25 5 L75 30 L25 55 L35 30 Z" />
          <path d="M50 10 L100 30 L50 50 L55 30 Z" />
        </svg>
      </span>
      <p class="text-zinc-400 font-body text-sm leading-relaxed pr-8" data-i18n="footer.tagline">
        Redefining the premium rental experience for the electric age.
        Precision, performance, and pure silence.
      </p>
    </div>

    <!-- Navigation -->
    <div class="flex flex-col gap-4">
      <span class="text-white font-bold uppercase text-xs tracking-widest mb-4" data-i18n="footer.nav.head"
        >Navigation</span
      >
      <a
        class="text-zinc-400 hover:text-primary transition-colors uppercase text-[10px] font-bold tracking-widest"
        href="/" data-i18n="nav.home">Home</a
      >
      <a
        class="text-zinc-400 hover:text-primary transition-colors uppercase text-[10px] font-bold tracking-widest"
        href="/fleet" data-i18n="nav.collection">Collection</a
      >
      <a
        class="text-zinc-400 hover:text-primary transition-colors uppercase text-[10px] font-bold tracking-widest"
        href="/contact" data-i18n="nav.policies">Policies & Contact</a
      >
      <a
        class="text-zinc-400 hover:text-primary transition-colors uppercase text-[10px] font-bold tracking-widest"
        href="/contact#map-section">Location</a
      >
    </div>

    <!-- Legal -->
    <div class="flex flex-col gap-4">
      <span class="text-white font-bold uppercase text-xs tracking-widest mb-4" data-i18n="footer.legal.head"
        >Legal</span
      >
      <a
        class="text-zinc-400 hover:text-primary transition-colors uppercase text-[10px] font-bold tracking-widest"
        href="/privacy" data-i18n="footer.privacy">Privacy</a
      >
      <a
        class="text-zinc-400 hover:text-primary transition-colors uppercase text-[10px] font-bold tracking-widest"
        href="/terms" data-i18n="footer.terms">Terms</a
      >
      <a
        class="text-zinc-400 hover:text-primary transition-colors uppercase text-[10px] font-bold tracking-widest"
        href="/contact">Contact</a
      >
    </div>

    <!-- Newsletter -->
    <div class="flex flex-col gap-4">
      <span class="text-white font-bold uppercase text-xs tracking-widest mb-4" data-i18n="footer.newsletter.head"
        >Newsletter</span
      >
      <p
        class="text-zinc-500 text-[10px] uppercase font-bold tracking-widest leading-loose mb-4"
        data-i18n="footer.newsletter.desc"
      >
        Join the collection for updates on new arrivals.
      </p>
      <form action="mailto:concierge@privatedrive.com" method="POST" enctype="text/plain" class="relative">
        <input
          name="newsletter_email"
          class="w-full bg-transparent border-b border-zinc-700 py-2 text-xs focus:border-primary outline-none text-white transition-colors"
          placeholder="YOUR EMAIL"
          data-i18n="footer.newsletter.placeholder"
          type="email"
          required
        />
        <button
          type="submit"
          class="absolute right-0 bottom-2 text-primary font-bold text-[10px] uppercase tracking-widest hover:text-white transition-colors duration-300 cursor-pointer"
          data-i18n="footer.newsletter.submit"
          >Submit</button
        >
      </form>
    </div>
  </div>

  <div
    class="px-6 md:px-20 py-8 border-t border-zinc-800 flex flex-col md:flex-row justify-center items-center gap-4"
  >
    <span class="text-zinc-500 text-[10px] font-bold tracking-[0.2em] uppercase text-center" data-i18n="footer.copyright"
      >© 2026 PRIVATE DRIVE. ENGINEERED FOR PRECISION.</span
    >

  </div>
</footer>
