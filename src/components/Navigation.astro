---
const pathname = new URL(Astro.url).pathname;
const currentPath = pathname === "/" ? "/" : pathname.replace(/\/$/, "");
---

<nav
  class="fixed top-0 w-full z-50 bg-black border-b border-white/5 flex justify-between items-center px-6 md:px-12 py-6 shadow-[0_10px_40px_0_rgba(0,0,0,0.5)]"
>
  <!-- Logo (left) -->
  <a href="/" class="z-50 transition-all flex items-center justify-center py-2">
    <img
      src="/pec logo (3).png"
      alt="Paris Elite Cars Logo"
      class="h-auto w-24 object-contain"
    />
  </a>

  <!-- Centered nav links (desktop) -->
  <div class="hidden md:flex gap-8 absolute left-1/2 -translate-x-1/2">
    <a
      class={`uppercase text-[10px] font-black tracking-[0.3em] transition-all duration-300 ${currentPath === "/" ? "text-primary" : "text-zinc-400 hover:text-primary"}`}
      href="/"
      data-i18n="nav.home">Home</a
    >
    <a
      class={`uppercase text-[10px] font-black tracking-[0.3em] transition-all duration-300 ${currentPath === "/fleet" ? "text-primary" : "text-zinc-400 hover:text-primary"}`}
      href="/fleet"
      data-i18n="nav.collection">Collection</a
    >
    <a
      class={`uppercase text-[10px] font-black tracking-[0.3em] transition-all duration-300 ${currentPath === "/contact" ? "text-primary" : "text-zinc-400 hover:text-primary"}`}
      href="/contact"
      data-i18n="nav.policies">Policies & Contact</a
    >
  </div>

  <!-- Right side (language toggle + reserve, mobile: hamburger) -->
  <div class="flex items-center gap-3 md:gap-8 z-50">
    <div
      class="flex items-center gap-1 bg-zinc-900/50 p-1 rounded-sm border border-white/10 shadow-inner"
    >
      <button
        onclick="window.switchLanguage('en')"
        data-lang-btn="en"
        class="px-3 py-1 text-[9px] font-bold tracking-[0.2em] uppercase transition-all duration-300 rounded-[2px] cursor-pointer"
        >EN</button
      >
      <button
        onclick="window.switchLanguage('fr')"
        data-lang-btn="fr"
        class="px-3 py-1 text-[9px] font-bold tracking-[0.2em] uppercase transition-all duration-300 rounded-[2px] cursor-pointer"
        >FR</button
      >
    </div>
    <a
      href="/contact"
      class="hidden md:block bg-primary text-black px-6 py-3 text-[10px] font-black uppercase tracking-[0.2em] shadow-lg shadow-primary/20 hover:bg-white hover:text-black transition-all active:scale-95"
      data-i18n="nav.reserve"
    >
      Reserve Now
    </a>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-toggle"
      class="block md:hidden flex items-center justify-center w-10 h-10 border border-white/10 bg-zinc-900 rounded-full hover:bg-zinc-800 transition-all text-white shadow-sm cursor-pointer group"
    >
      <span
        class="material-symbols-outlined text-xl group-hover:text-primary transition-colors"
        >menu</span
      >
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed top-0 left-0 w-full h-dvh bg-black z-999 flex flex-col justify-center items-start px-10 opacity-0 pointer-events-none transition-opacity duration-300"
>
  <!-- Close Button Top Right -->
  <button
    id="mobile-menu-close"
    class="absolute top-8 right-8 text-white hover:text-primary transition-colors"
  >
    <span class="material-symbols-outlined text-4xl">close</span>
  </button>

  <div class="flex flex-col gap-8 w-full">
    <a
      class="text-white uppercase text-4xl font-black tracking-tighter hover:text-primary transition-colors text-left mobile-link"
      href="/"
      data-i18n="nav.home">Home</a
    >
    <a
      class="text-white uppercase text-4xl font-black tracking-tighter hover:text-primary transition-colors text-left mobile-link"
      href="/fleet"
      data-i18n="nav.collection">Collection</a
    >
    <a
      class="text-white uppercase text-4xl font-black tracking-tighter hover:text-primary transition-colors text-left leading-none mobile-link"
      href="/contact"
      data-i18n="nav.policies">Policies & Contact</a
    >
  </div>

  <div
    class="mt-16 border-t border-white/10 pt-8 flex flex-col gap-8 items-start w-full max-w-sm"
  >
    <a
      href="/contact"
      class="bg-primary text-black w-full py-5 text-[10px] font-black uppercase tracking-[0.2em] shadow-lg shadow-primary/20 text-center hover:bg-white transition-colors cursor-pointer mobile-link"
      data-i18n="nav.reserve">Reserve Now</a
    >
  </div>
</div>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById("mobile-menu-toggle");
    const closeBtn = document.getElementById("mobile-menu-close");
    const menu = document.getElementById("mobile-menu");
    if (!toggle || !menu || !closeBtn) return;

    function openMenu() {
      if (!menu) return;
      menu.classList.remove("opacity-0", "pointer-events-none");
      menu.classList.add("opacity-100", "pointer-events-auto");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      if (!menu) return;
      menu.classList.remove("opacity-100", "pointer-events-auto");
      menu.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
    }

    toggle.addEventListener("click", openMenu);
    closeBtn.addEventListener("click", closeMenu);

    // Close menu when clicking a link
    menu.querySelectorAll(".mobile-link").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  document.addEventListener("DOMContentLoaded", initMobileMenu);
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
