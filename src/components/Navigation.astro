---

---

<nav
  class="fixed top-0 w-full z-50 bg-white/70 backdrop-blur-xl flex justify-between items-center px-6 md:px-12 py-6 shadow-[0_10px_40px_0_rgba(0,0,0,0.04)]"
>
  <!-- Logo (left) -->
  <a
    href="/"
    class="text-zinc-900 z-50 transition-all flex items-center justify-center py-2"
    >
    <svg viewBox="0 0 100 60" class="w-12 h-auto text-zinc-900 fill-current" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 0 L60 30 L0 60 L15 30 Z" />
      <path d="M25 5 L75 30 L25 55 L35 30 Z" />
      <path d="M50 10 L100 30 L50 50 L55 30 Z" />
    </svg>
  </a>

  <!-- Centered nav links (desktop) -->
  <div class="hidden md:flex gap-8 absolute left-1/2 -translate-x-1/2">
    <a
      class="text-zinc-500 uppercase text-xs font-semibold tracking-widest hover:text-primary transition-all duration-300"
      href="/" data-i18n="nav.home">Home</a
    >
    <a
      class="text-zinc-500 uppercase text-xs font-semibold tracking-widest hover:text-primary transition-all duration-300"
      href="/fleet" data-i18n="nav.collection">Collection</a
    >
    <a
      class="text-zinc-500 uppercase text-xs font-semibold tracking-widest hover:text-primary transition-all duration-300"
      href="/contact" data-i18n="nav.policies">Policies & Contact</a
    >
  </div>

  <!-- Right side (language toggle + reserve, mobile: hamburger) -->
  <div class="flex items-center gap-3 md:gap-8 z-50">
    <div class="flex items-center gap-1 bg-zinc-100 p-1 rounded-sm border border-zinc-200/50 shadow-inner">
      <button 
        onclick="window.switchLanguage('en')" 
        data-lang-btn="en"
        class="px-3 py-1 text-[9px] font-bold tracking-[0.2em] uppercase transition-all duration-300 rounded-[2px] cursor-pointer"
      >EN</button>
      <button 
        onclick="window.switchLanguage('fr')" 
        data-lang-btn="fr"
        class="px-3 py-1 text-[9px] font-bold tracking-[0.2em] uppercase transition-all duration-300 rounded-[2px] cursor-pointer"
      >FR</button>
    </div>
    <a 
      href="/contact" 
      class="hidden md:block bg-primary text-white px-6 py-3 text-[10px] font-black uppercase tracking-[0.2em] shadow-lg shadow-primary/20 hover:bg-zinc-900 transition-all active:scale-95"
      data-i18n="nav.reserve"
    >
      Reserve Now
    </a>
    
    <!-- Mobile Menu Toggle -->
    <button id="mobile-menu-toggle" class="block md:hidden flex items-center justify-center w-10 h-10 border border-zinc-200 bg-white rounded-full hover:bg-zinc-50 transition-all text-zinc-900 shadow-sm cursor-pointer group">
      <span class="material-symbols-outlined text-xl group-hover:text-primary transition-colors">menu</span>
    </button>
  </div>

</nav>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed top-0 left-0 w-full h-dvh bg-white z-999 flex flex-col justify-center items-start px-10 opacity-0 pointer-events-none transition-opacity duration-300">
    <!-- Close Button Top Right -->
    <button id="mobile-menu-close" class="absolute top-8 right-8 text-zinc-900 hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-4xl">close</span>
    </button>
    
    <div class="flex flex-col gap-8 w-full">
      <a class="text-zinc-900 uppercase text-4xl font-black tracking-tighter hover:text-primary transition-colors text-left mobile-link" href="/" data-i18n="nav.home">Home</a>
      <a class="text-zinc-900 uppercase text-4xl font-black tracking-tighter hover:text-primary transition-colors text-left mobile-link" href="/fleet" data-i18n="nav.collection">Collection</a>
      <a class="text-zinc-900 uppercase text-4xl font-black tracking-tighter hover:text-primary transition-colors text-left leading-none mobile-link" href="/contact" data-i18n="nav.policies">Policies & Contact</a>
    </div>
    
    <div class="mt-16 border-t border-zinc-100 pt-8 flex flex-col gap-8 items-start w-full max-w-sm">
      <a href="/contact" class="bg-primary text-white w-full py-5 text-[10px] font-black uppercase tracking-[0.2em] shadow-lg shadow-primary/20 text-center hover:bg-zinc-900 transition-colors cursor-pointer mobile-link" data-i18n="nav.reserve">Reserve Now</a>
    </div>
  </div>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu || !closeBtn) return;

    function openMenu() {
      if (!menu) return;
      menu.classList.remove('opacity-0', 'pointer-events-none');
      menu.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      if (!menu) return;
      menu.classList.remove('opacity-100', 'pointer-events-auto');
      menu.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    // Close menu when clicking a link
    menu.querySelectorAll('.mobile-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  document.addEventListener('DOMContentLoaded', initMobileMenu);
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
