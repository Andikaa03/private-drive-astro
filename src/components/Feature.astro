---
import { fleet } from "../data/fleet.js";
const featureCar = fleet.find((car) => car.id === "tesla-model-s-plaid")!;
---

<section class="bg-surface py-24 overflow-hidden border-t border-white/5">
  <div class="editorial-grid">
    <div
      class="col-span-12 md:col-start-2 md:col-span-4 self-center px-6 md:px-0 fade-up"
    >
      <h2
        class="text-4xl md:text-5xl font-black text-white tracking-tighter uppercase mb-8 leading-none"
        data-i18n="feature.title"
      >
        Silent<br />Authority.
      </h2>
      <p
        class="text-zinc-400 text-xs uppercase tracking-widest mb-12 leading-relaxed italic"
        data-i18n={`car.${featureCar.id}.vibe`}
      >
        "{featureCar.vibe}"
      </p>
      <div class="grid grid-cols-2 gap-8">
        <div>
          <span
            class="block text-zinc-400 font-bold text-[10px] tracking-widest uppercase mb-2"
            data-i18n="car.stats.power">POWER</span
          >
          <span class="text-primary font-black text-4xl tracking-tighter"
            >{featureCar.stats.power}</span
          >
        </div>
        <div>
          <span
            class="block text-zinc-400 font-bold text-[10px] tracking-widest uppercase mb-2"
            data-i18n="car.stats.range">RANGE</span
          >
          <span class="text-primary font-black text-4xl tracking-tighter"
            >{featureCar.stats.range}</span
          >
        </div>
      </div>
    </div>

    <div
      class="col-span-12 md:col-start-7 md:col-span-6 relative mt-16 md:mt-0 fade-up flex items-center justify-center bg-zinc-900 border-l border-white/5"
    >
      <div
        class="absolute -left-12 top-12 bottom-12 w-24 bg-surface z-10 hidden md:block"
      >
      </div>
      <img
        class="w-full max-w-2xl h-auto object-contain p-12"
        alt={featureCar.name}
        src={featureCar.image}
      />
      <div
        class="absolute bottom-0 left-0 bg-primary p-8 md:p-12 text-black max-w-xs transform translate-y-12 md:translate-x-12 hidden md:block"
      >
        <p class="text-[9px] font-black uppercase tracking-[0.3em] mb-4 opacity-70" data-i18n="feature.box.head">
          FEATURED COLLECTION
        </p>
        <p class="text-xl font-black leading-tight uppercase tracking-tighter">
          {featureCar.brand}
          {featureCar.name} — <span data-i18n={`car.${featureCar.id}.feature0`}>{featureCar.topFeatures[0]}</span>
        </p>
      </div>
    </div>
  </div>
</section>
