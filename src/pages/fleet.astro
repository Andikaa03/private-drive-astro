---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { fullFleet } from '../data/fleet.js';

const featuredCars = fullFleet.filter(car => car.featured);
const otherCars = fullFleet.filter(car => !car.featured);
---

<Layout title="Our Fleet | Private Drive Premium Collection">
  <main class="bg-white pt-24">
    <!-- Header Section -->
    <header class="max-w-[1440px] mx-auto px-6 md:px-24 py-20 border-b border-zinc-100">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-12">
        <div class="max-w-2xl fade-up">
          <p class="text-[10px] font-bold text-primary uppercase tracking-[0.5em] mb-4" data-i18n="fleet.pg.top">Exceptional Rental Profiles</p>
          <h1 class="text-6xl md:text-8xl font-black text-zinc-900 uppercase tracking-tighter leading-[0.85] mb-8" data-i18n="fleet.pg.head">
            The Curated<br/>Autodrome
          </h1>
          <p class="text-zinc-500 text-sm md:text-base leading-relaxed font-medium" data-i18n="fleet.pg.desc">
            An curated selection of high-performance machines, chosen for technical prowess and aesthetic significance.
          </p>
        </div>
        <div class="hidden md:block text-right">
          <p class="text-[10px] font-bold text-zinc-300 uppercase tracking-widest" data-i18n="fleet.pg.core">Core Collection</p>
          <p class="text-2xl font-black text-zinc-900 mt-1" data-i18n="fleet.pg.units">01 — 04 UNITS</p>
        </div>
      </div>
    </header>

    <!-- Section 1: Core Collection -->
    <section class="max-w-[1440px] mx-auto px-6 md:px-24 py-20 pb-40">
      <div class="flex flex-col gap-32">
        {featuredCars.map((car, index) => (
          <div class={`flex flex-col ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-12 md:gap-24 items-center fade-up`}>
            <!-- Hero Image Frame -->
            <div class="w-full md:w-1/2 relative bg-zinc-50 border border-zinc-100 p-4">
              <div class="absolute top-8 left-8 z-10">
                <span class={`px-4 py-1.5 text-[9px] font-black uppercase tracking-[0.3em] ${car.status === 'Available' ? 'bg-primary text-white' : 'bg-red-600 text-white'}`}>
                  <span data-i18n={`status.${car.status}`}>{car.status}</span> / <span data-i18n={`color.${car.color}`}>{car.color}</span>
                </span>
              </div>
              <div class="aspect-[16/10] overflow-hidden">
                <img 
                  src={car.image} 
                  alt={car.name}
                  class="w-full h-full object-cover"
                />
              </div>
            </div>

            <!-- Detailed Content -->
            <div class="w-full md:w-1/2 flex flex-col">
              <div class="mb-10">
                <div class="flex items-center gap-4 mb-4">
                  <span class="text-[10px] font-black text-primary uppercase tracking-[0.5em]">{car.brand} {car.year}</span>
                  <span class="text-zinc-300">/</span>
                  <span class="text-sm font-black text-zinc-900 tracking-widest">{car.price} <span class="text-[10px] font-bold text-zinc-400 uppercase" data-i18n="collection.day">Per Day</span></span>
                </div>
                <h2 class="text-5xl md:text-7xl font-black text-zinc-900 uppercase tracking-tighter leading-[0.9] mb-6">
                  {car.name}
                </h2>
                <p class="text-sm font-medium text-zinc-500 leading-relaxed italic max-w-lg border-l-2 border-primary pl-4 py-1">
                  "<span data-i18n={`car.${car.id}.vibe`}>{car.vibe}</span>"
                </p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
                <!-- Features -->
                <div>
                  <h4 class="text-[10px] font-black text-zinc-900 uppercase tracking-[0.3em] mb-4 border-b border-zinc-100 pb-2" data-i18n="fleet.pg.features">Top Features</h4>
                  <ul class="space-y-3">
                    {car.topFeatures?.map((feature, idx) => (
                      <li class="flex items-start gap-3">
                        <span class="text-primary text-xs mt-0.5">&bull;</span>
                        <span class="text-[11px] font-bold text-zinc-600 uppercase tracking-widest leading-relaxed" data-i18n={`car.${car.id.replace(/-unit-\d+$/, '').replace(/-\d+$/, '')}.feat${idx}`}>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Technical Details -->
                <div>
                  <h4 class="text-[10px] font-black text-zinc-900 uppercase tracking-[0.3em] mb-4 border-b border-zinc-100 pb-2" data-i18n="fleet.pg.details">The Details</h4>
                  <ul class="space-y-3">
                    {car.theDetails?.map((detail, idx) => (
                      <li class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-sm text-zinc-300">verified</span>
                        <span class="text-[11px] font-medium text-zinc-500 uppercase tracking-widest leading-relaxed" data-i18n={`car.${car.id.replace(/-unit-\d+$/, '').replace(/-\d+$/, '')}.detail${idx}`}>{detail}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="mb-12">
                <h4 class="text-[10px] font-black text-zinc-300 uppercase tracking-[0.3em] mb-4" data-i18n="fleet.pg.bestfor">Best Suited For</h4>
                <div class="flex flex-wrap gap-2">
                  {car.bestFor?.map((useCase, idx) => (
                    <span class="bg-zinc-50 border border-zinc-100 px-3 py-2 text-[8px] font-black text-zinc-500 uppercase tracking-widest truncate" data-i18n={`car.${car.id.replace(/-unit-\d+$/, '').replace(/-\d+$/, '')}.best${idx}`}>
                      {useCase}
                    </span>
                  ))}
                </div>
              </div>

              <a 
                href="/contact" 
                class="inline-block bg-primary text-white px-12 py-5 text-[10px] font-black uppercase tracking-[0.4em] text-center hover:bg-zinc-900 transition-all active:scale-95 shadow-xl hover:shadow-2xl self-start"
                data-i18n="fleet.pg.reserve"
              >
                Inquire & Reserve
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    {otherCars.length > 0 && (
      <!-- Section 2: Architectural Expansion -->
      <section class="max-w-[1440px] mx-auto px-6 md:px-24 py-32 bg-zinc-50 border-t border-zinc-200">
        <div class="mb-20 fade-up">
          <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-[0.5em] mb-4" data-i18n="fleet.pg.expansion.top">Extended Inventory</p>
          <h2 class="text-4xl md:text-5xl font-black text-zinc-900 uppercase tracking-tighter" data-i18n="fleet.pg.expansion.head">
            The Architectural<br/>Expansion
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {otherCars.map((car) => (
            <div class="bg-white p-6 border border-zinc-200 group flex flex-col fade-up">
              <div class="aspect-square overflow-hidden bg-zinc-100 mb-6">
                <img 
                  src={car.image} 
                  alt={car.name}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
              </div>
              <div class="mb-8 flex-1">
                <p class="text-[8px] font-bold text-primary uppercase tracking-widest mb-1">{car.brand} {car.year}</p>
                <h4 class="text-lg font-black text-zinc-900 uppercase tracking-tighter truncate">{car.name}</h4>
                <p class="text-[10px] text-zinc-500 mt-2 line-clamp-3 leading-relaxed"><span data-i18n={`car.${car.id}.vibe`}>{car.vibe}</span></p>
                
                <div class="mt-4 pt-4 border-t border-zinc-100 grid grid-cols-2 gap-4">
                  <div class="flex flex-col">
                    <span class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest" data-i18n="car.status.power">Pricing</span>
                    <span class="text-xs font-bold text-zinc-900">{car.price}<span data-i18n="collection.day">/Day</span></span>
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[7px] text-zinc-400 uppercase font-bold tracking-widest" data-i18n="car.stats.seats">Seats</span>
                    <span class="text-xs font-bold text-zinc-900">{car.stats.seats} Total</span>
                  </div>
                </div>
              </div>
              <a 
                href="/contact" 
                class={`w-full py-3 text-[9px] font-bold uppercase tracking-[0.2em] text-center transition-all inline-block ${car.status === 'Booked' ? 'bg-zinc-100 text-zinc-400 cursor-not-allowed' : 'bg-primary text-white hover:bg-zinc-900'}`}
                data-i18n={car.status === 'Booked' ? 'fleet.pg.expansion.booked' : 'fleet.pg.expansion.btn'}
              >
                {car.status === 'Booked' ? 'Booked' : 'Reserve'}
              </a>
            </div>
          ))}

          <!-- Incentive Card -->
          <div class="bg-primary p-10 flex flex-col justify-between text-white group cursor-pointer relative overflow-hidden fade-up">
            <div class="relative z-10">
              <div class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center mb-10 group-hover:bg-white group-hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </div>
              <h4 class="text-2xl font-black uppercase tracking-tighter leading-none mb-4" data-i18n="fleet.pg.incentive.head">
                Inquire About<br/>Custom Incentive
              </h4>
            </div>
            <p class="relative z-10 text-[10px] font-bold uppercase tracking-widest opacity-70 group-hover:opacity-100 transition-opacity" data-i18n="fleet.pg.incentive.sub">
              Talk to concierge &rarr;
            </p>
            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-white/5 rounded-full mix-blend-overlay group-hover:scale-150 transition-transform duration-1000"></div>
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>
