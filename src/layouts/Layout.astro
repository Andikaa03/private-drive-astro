      function updateLanguage(lang) {
        document.documentElement.lang = lang;
        localStorage.setItem('preferred-lang', lang);
        
        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          if (translations[lang] && translations[lang][key]) {
            const translation = translations[lang][key];
            if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
              el.placeholder = translation;
            } else if (el.tagName === 'OPTION') {
              el.textContent = translation;
            } else {
              el.textContent = translation;
            }
          }
        });

        // Update active toggle state
        document.querySelectorAll('[data-lang-btn]').forEach(btn => {
          if (btn.getAttribute('data-lang-btn') === lang) {
            btn.classList.add('bg-primary', 'text-white', 'shadow-sm');
            btn.classList.remove('text-zinc-400', 'hover:text-zinc-900', 'hover:bg-zinc-200/50');
          } else {
            btn.classList.remove('bg-primary', 'bg-zinc-900', 'text-white', 'shadow-sm');
            btn.classList.add('text-zinc-400', 'hover:text-zinc-900', 'hover:bg-zinc-200/50');
          }
        });
      }

      // Intersection Observer for animations
      let staggerTimer = null;
      let staggerCount = 0;

      function initAnimations() {
        const fadeEls = document.querySelectorAll('.fade-up');
        if (fadeEls.length > 0) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                // Use a global stagger to ensure sequence even across batches
                const currentStagger = staggerCount;
                staggerCount++;
                
                // Reset stagger count after a short break in intersections
                clearTimeout(staggerTimer);
                staggerTimer = setTimeout(() => {
                  staggerCount = 0;
                }, 400);

                setTimeout(() => {
                  entry.target.classList.add('is-visible');
                }, currentStagger * 100);
                
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
          fadeEls.forEach(el => observer.observe(el));
        }
      }

      // Single event handler for page loads/transitions
      function setup() {
        const savedLang = localStorage.getItem('preferred-lang') || 'en';
        updateLanguage(savedLang);
        initAnimations();
      }

      // Initial load
      document.addEventListener('DOMContentLoaded', setup);
      // View Transitions load
      document.addEventListener('astro:page-load', setup);

      window.switchLanguage = (lang) => {
        updateLanguage(lang);
      };
    </script>
